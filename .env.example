# Copy to .env and fill in your values.
# Chainlit chat + MCP: OPENAI_API_KEY, Jira/Qase vars as needed for your MCP servers.
# CI agents (GitHub Actions) also use Jira, Qase, GitHub, GPS_*, BASE_URL, LLM keys.

# ── Chainlit: ChatGPT-style history (left sidebar, past threads) ──
# Chainlit stores threads only when DATABASE_URL points at PostgreSQL with the official schema applied.
# Quick path: `docker compose up -d` in this repo, then clone https://github.com/Chainlit/chainlit-datalayer ,
# set the same DATABASE_URL there, run `npx prisma migrate deploy`, then set the variables below and restart Chainlit.
# Requires `pip install asyncpg` (listed in requirements.txt).
# DATABASE_URL=postgresql://chainlit:chainlit@localhost:5432/chainlit
# JWT secret for login cookies — run: chainlit create-secret
# CHAINLIT_AUTH_SECRET=
# Password login (optional; use OAuth/header auth instead if you prefer — see Chainlit auth docs).
# CHAINLIT_HISTORY_USER=admin
# CHAINLIT_HISTORY_PASSWORD=change-me

# Application under test
BASE_URL=https://qa3.gps.aegm.com
TEST_ENV=gps-qa3

# GPS login credentials (used by tests and executor/healer agents)
GPS_EMAIL=your-email@example.com
GPS_PASSWORD=your-password

# Playwright MCP (@playwright/mcp): visible browser window. Applied if your MCP launcher passes env into the Playwright server
# (e.g. Chainlit with CHAINLIT_MCP_FULL_ENV=1). Do NOT pass --headless in MCP args if you want a window.
# PLAYWRIGHT_MCP_HEADLESS=false
# Terminal `npx playwright test` is separate — use `npm run test:headed` or `--headed` for a visible window.

# Qase API token — https://app.qase.io/user/api/token
QASE_API_TOKEN=
# Qase project short code (as in Qase UI / list_projects) — stops models from sending your_project_code on create_run
# QASE_PROJECT_CODE=PRJ

# GitHub default repo for MCP (owner/repo) — stops models from using username/repository placeholders on get_file_contents
# If unset or wrong vs `git remote origin`, Chainlit aligns GITHUB_REPOSITORY with origin (so the running checkout wins over a typo like owner/AE).
# Omit GITHUB_REPOSITORY to rely entirely on git, or set it to the exact github.com slug for this clone.
# GITHUB_REPOSITORY=your-org/AE.QA.Agentic.HumanLoop.Chainlit
# Prefer .env over `git remote origin` for owner/repo (rare; fork / no .git). Default0.
# CHAINLIT_GITHUB_REPOSITORY_TRUST_ENV=1
# Default base branch for GitHub MCP create_branch when the model omits from_branch (default main).
# GITHUB_DEFAULT_BRANCH=main
# GitHub Copilot MCP — remote URL + Authorization (Cursor mcp.json parity). For stdio in Chainlit use `node chainlit-github-mcp.cjs` (see `npm run mcp:github`); do not commit secrets.
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# GITHUB_MCP_AUTHORIZATION=ghp_... # or Bearer ... — if unset, chainlit-github-mcp.cjs falls back to GITHUB_TOKEN / GH_TOKEN
# Or split:
# GITHUB_DEFAULT_OWNER=your-org
# GITHUB_DEFAULT_REPO=AE.QA.Agentic.HumanLoop.Chainlit
# Rewrite wrong owner/repo on GitHub MCP calls that take owner+repo (including get_file_contents, list_branches, PR/issue APIs) to match GITHUB_REPOSITORY / git origin. Skips search_* and fork_repository. Default 1.
# CHAINLIT_GITHUB_PIN_WORKSPACE_REPO=0

# Jira — https://id.atlassian.com/manage-profile/security/api-tokens
# Cloud ID (UUID) for Atlassian Cloud — used when Rovo MCP needs `cloudId` and discovery is unclear. Admin: Jira → Settings → System → System information, or from `getAccessibleAtlassianResources`.
JIRA_CLOUD_ID=
# Optional: comma-separated Jira *project* keys to skip when matching PROJ-123 in chat (default excludes TC — Qase-style TC-356). Set empty to allow TC as Jira.
# CHAINLIT_JIRA_KEY_EXCLUDE_PROJECTS=TC
JIRA_API_TOKEN=
JIRA_EMAIL=
# Optional: Rovo MCP–scoped token for Chainlit (chainlit-atlassian-mcp.cjs). If unset, JIRA_API_TOKEN is used.
# JIRA_MCP_API_TOKEN=
# Optional: override Atlassian MCP URL (default https://mcp.atlassian.com/v1/mcp)
# ATLASSIAN_MCP_URL=
# Inject `JIRA_CLOUD_ID` into the LLM system prompt so it does not ask you for a cloud ID (default 1).
# CHAINLIT_INJECT_JIRA_CLOUD_ID=1
# When `JIRA_CLOUD_ID` is set, replace wrong model-supplied `cloudId` on Jira/Atlassian MCP calls (default 1). Set 0 to disable.
# CHAINLIT_FORCE_JIRA_CLOUD_ID_FROM_ENV=1

# Optional: Chainlit MCP stdio — inherit full environment to child (node/npx), like your terminal. Try if connections still close.
# CHAINLIT_MCP_FULL_ENV=1
#
# If you see "unhandled errors in a TaskGroup", the real cause is in the chained exception — run Chainlit in a terminal
# for the full traceback, or upgrade chainlit+mcp (`pip install -U chainlit mcp`), or use streamable-http for Atlassian in MCP settings.
# Optional: JSON merged into Jira create-issue payload (required custom fields on some projects)
# Example: {"customfield_10130":{"value":"Bug"}}
# JIRA_CREATE_ISSUE_EXTRA_FIELDS=
# Optional: valid priority name for Bugs in your Jira project (omit if unsure)
# JIRA_BUG_PRIORITY_NAME=Medium

# Optional: Qase defect default severity (1–6) when create_defect omits severity
# QASE_DEFECT_DEFAULT_SEVERITY=4

# Optional: Playwright exec timeout in CI ms (default 600000)
# PLAYWRIGHT_EXEC_TIMEOUT_MS=600000

# LLM — use one of:
# OPENAI_API_KEY — https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY — https://console.anthropic.com/
OPENAI_API_KEY=
# Optional: model for Chainlit chat + MCP tool routing (default gpt-4.1)
# CHAINLIT_OPENAI_MODEL=gpt-4.1
# Optional: comma-separated models shown in Chainlit chat settings (gear). Current CHAINLIT_OPENAI_MODEL is always listed.
# Comma-separated; default list includes gpt-4.1, gpt-4.1-mini, gpt-4o, gpt-4o-mini, gpt-4-turbo, o3-mini, o4-mini
# CHAINLIT_UI_MODEL_CHOICES=gpt-4.1,gpt-4.1-mini,gpt-4o,gpt-4o-mini,gpt-4-turbo,o3-mini,o4-mini
# When 1 (default), Pipeline / Planner / Qase / Automation / Orchestrator starters prompt for Jira key (and feature slug for Automation) instead of using template text.
# CHAINLIT_STARTER_INPUT_PROMPTS=1
# Timeout seconds for each starter AskUser prompt (default 300)
# CHAINLIT_STARTER_INPUT_TIMEOUT=300
# Corporate SSL / proxy: if OpenAI returns "Connection error", set CA bundle path OR dev-only verify off
# CHAINLIT_SSL_CA_BUNDLE=C:\path\to\corp-root-ca.pem
# CHAINLIT_OPENAI_VERIFY_SSL=0
# Use Windows/macOS certificate store (recommended on corporate PCs; requires: pip install truststore)
# CHAINLIT_USE_TRUSTSTORE=1
# HTTPS_PROXY=http://proxy.company.com:8080
# Optional: skip quick OpenAI probe (models.list) if your endpoint differs (e.g. some Azure setups)
# CHAINLIT_SKIP_OPENAI_PROBE=1
# CHAINLIT_OPENAI_PROBE_TIMEOUT=20
# Optional: Azure OpenAI or API gateway base URL
# CHAINLIT_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
# Optional: avoid “stuck” UI — timeouts (seconds) and max MCP tools sent to OpenAI (Qase exposes many tools)
# First chat.completions call with many tools + skills can need >120s — raise if Step 3 times out.
# CHAINLIT_OPENAI_TIMEOUT=120
# CHAINLIT_CHAT_TOTAL_TIMEOUT=240
# Longer wall clock for phrases like “complete workflow” / “full pipeline” (default 900)
# CHAINLIT_CHAT_TOTAL_TIMEOUT_WORKFLOW=900
# Prior Chainlit turns are sent to OpenAI (so follow-ups keep Jira keys / context). Caps:
# CHAINLIT_THREAD_HISTORY_MAX_MESSAGES=48
# CHAINLIT_HEURISTIC_THREAD_MAX_CHARS=16000
# Per-MCP list_tools budget (connections are listed in parallel; worst case ~= this value, not N×this)
# CHAINLIT_MCP_LIST_TOOLS_TIMEOUT=45
# CHAINLIT_MCP_CALL_TOOL_TIMEOUT=90
# Max chars per server shown in `/mcp-setup` Chainlit Step output (default 2400)
# CHAINLIT_MCP_PROBE_OUTPUT_MAX=2400
# When 1, pasting the Setup «MCP plug + Playwright env» starter (or legacy checklist text) runs `/mcp-setup` automatically (no OpenAI). Set 0 to disable.
# CHAINLIT_MCP_CHECKLIST_AUTO_PROBE=1
# CHAINLIT_MCP_MAX_TOOLS=35
# OpenAI Chat Completions allows at most 128 tools; this app caps mirrored MCP tools to that (override ceiling only downward).
# CHAINLIT_OPENAI_MAX_TOOLS=128
# Full-workflow phrases use a smaller tool list (saves ~2k+ tokens in “functions”)
# CHAINLIT_MCP_MAX_TOOLS_WORKFLOW=28
# When the thread is a full pipeline / Qase work, reserve this many Qase MCP tools **first** so Atlassian does not fill the cap alone
# CHAINLIT_MCP_QASE_TOOL_RESERVE=14
# Omit Qase MCP delete_* tools from the OpenAI tool list (default on — avoids destructive calls / token errors). Set 0 to expose them.
# CHAINLIT_MCP_QASE_EXCLUDE_DELETE_TOOLS=1
# Truncate each NEW MCP tool message (default 12000). Full-workflow default is tighter.
# CHAINLIT_MCP_TOOL_RESULT_MAX_CHARS=12000
# For getJiraIssue-sized JSON: prepend summary/description preview before truncating (default 1).
# CHAINLIT_JIRA_ISSUE_SMART_TRUNCATE=1
# CHAINLIT_MCP_TOOL_RESULT_MAX_CHARS_WORKFLOW=8000
# Older tool steps in the same chat are truncated more aggressively (default 1800 chars)
# CHAINLIT_MCP_TOOL_LEGACY_MAX_CHARS=1800
# Keep the last N tool messages at “full” cap before legacy truncation (default 6)
# CHAINLIT_MCP_TOOL_RESULT_KEEP_LAST=6
# Skip duplicate identical MCP calls in the same chat turn (reads, addCommentToJiraIssue, create_suite, create_case, …). Set 0 to always call.
# CHAINLIT_MCP_DEDUP_IDENTICAL_CALLS=1
# Remember successful Qase create_suite (project code + title) and create_case (same payload) for the Chainlit browser session so repeats are skipped across turns/messages. Set 0 to disable.
# CHAINLIT_MCP_SESSION_DEDUP_QASE_CREATES=1
# Remember successful read-only MCP results across user messages (same browser session). Default: getJiraIssue + getAccessibleAtlassianResources.
# CHAINLIT_MCP_SESSION_CACHE_READS=1
# CHAINLIT_MCP_SESSION_CACHE_TOOLS=getJiraIssue,getAccessibleAtlassianResources
# Or: all deduped read tools — CHAINLIT_MCP_SESSION_CACHE_TOOLS=all
# CHAINLIT_MCP_SESSION_CACHE_MAX_ENTRIES=80
# Shorter function descriptions in the OpenAI tools list (default 512)
# CHAINLIT_OPENAI_FUNCTION_DESC_MAX=512
# Hard cap on system prompt size (workflow uses WORKFLOW default)
# CHAINLIT_SYSTEM_PROMPT_MAX_CHARS=48000
# CHAINLIT_SYSTEM_PROMPT_MAX_CHARS_WORKFLOW=26000
# Omit noisy MCP tools by exact name (comma-separated). Merged with minimal-Jira set when enabled.
# CHAINLIT_MCP_TOOL_DENYLIST=getVisibleJiraProjects
# When the message looks like a Jira issue key (PROJ-123), hide Bitbucket tools (models confuse GPS-7525 with repo ids).
# CHAINLIT_MCP_AUTO_DENY_BITBUCKET_FOR_JIRA_KEY=1
# For "Fetch PROJ-123" / read-only fetch prompts, hide editJiraIssue, atlassianUserInfo, getConfluenceCommentChildren, addWorklogToJiraIssue (models confuse Jira keys with Confluence ids).
# CHAINLIT_MCP_DENY_EDIT_AND_USERINFO_ON_FETCH=1
# If JIRA_CLOUD_ID / ATLASSIAN_CLOUD_ID is set, hide getAccessibleAtlassianResources on fetch prompts (use cloudId from .env).
# CHAINLIT_MCP_SKIP_GET_ACCESSIBLE_WHEN_CLOUD_ID=1
# Block Confluence-named MCP tools on "Fetch PROJ-123" prompts (Jira keys are not Confluence ids). Set 0 to allow.
# CHAINLIT_MCP_FETCH_BLOCK_CONFLUENCE_TOOLS=1
# Full-workflow phrases ("run workflow", …): hide atlassianUserInfo and addWorklogToJiraIssue (not required by orchestrator skills).
# CHAINLIT_MCP_DENY_SPAM_TOOLS_ON_WORKFLOW=1
# Minimal Jira toolset for requirement/gap analysis (not full pipeline): hide huge discovery calls.
# auto | 1 | 0 — auto hides getVisibleJiraProjects when the message looks like Jira analysis (not “complete workflow”).
# CHAINLIT_MCP_JIRA_MINIMAL=auto
# Gap / requirement analysis (not “complete workflow”): after one successful getJiraIssue for the user’s issue key, remove getJiraIssue from the tool list so the model cannot repeat it (use JQL for linked issues). Set 0 to disable.
# CHAINLIT_GAP_ANALYSIS_STRIP_GET_JIRA_AFTER_PRIMARY=1
# MCP tool rounds per chat (default 24). Full-workflow phrases use the higher of this and WORKFLOW (default 48).
# CHAINLIT_MCP_MAX_ROUNDS=24
# CHAINLIT_MCP_MAX_ROUNDS_WORKFLOW=48
# Max characters of MCP result shown in each Chainlit step preview (full text still goes to the model)
# CHAINLIT_MCP_STEP_OUTPUT_MAX=12000
# Max addCommentToJiraIssue calls per issue per chat turn (after dedupe; 0 = unlimited). Default 1 = one gap-report comment.
# CHAINLIT_MCP_MAX_ADD_COMMENT_PER_TURN=1
# Block addComment until getJiraIssue succeeds for that issue in this chat turn (default on). Set 0 to disable.
# CHAINLIT_REQUIRE_GET_JIRA_BEFORE_ADD_COMMENT=1
# Block getJiraIssue when issueIdOrKey looks like a Qase public id (TC-123), not a Jira key
# CHAINLIT_BLOCK_GET_JIRA_FOR_TC_KEYS=1
# Optional: show Chainlit Steps for blocked/limit skips (default off — keeps the UI quiet when the model spams).
# CHAINLIT_MCP_STEP_ON_ADD_COMMENT_BLOCK=0
# CHAINLIT_MCP_STEP_ON_ADD_COMMENT_LIMIT=0
# Session-cached MCP reads (e.g. getJiraIssue): default no Step — model still gets JSON; set 1 to show “(session cache)” in UI.
# CHAINLIT_MCP_STEP_ON_SESSION_CACHE=0
# MCP tool Steps in the UI: default collapsed. Set to 1 to expand Jira/Qase steps (inputs/outputs visible without clicking).
# CHAINLIT_MCP_PROGRESS_STEPS_EXPAND=1
# Optional: emit a short chat line before each live Qase MCP call (in addition to the step)
# CHAINLIT_MCP_QASE_STATUS_MESSAGES=0
# Human-in-the-loop: OpenAI tool ``chainlit_ask_user`` → Chainlit AskUserMessage (default off; set 1 to enable)
# CHAINLIT_ASK_USER_TOOL=0
# CHAINLIT_ASK_USER_TIMEOUT=300
# CHAINLIT_ASK_USER_TOOL_NAME=chainlit_ask_user
# If the MCP tool list already hits CHAINLIT_MCP_MAX_TOOLS, set 1 to drop the last MCP tool and add ask_user (use sparingly)
# CHAINLIT_ASK_USER_TOOL_FORCE=0
#
# Skills in the OpenAI system prompt (`.github/skills`, `.github/rules/mcp-usage.md`) + MCP for execution
# Per-chat overrides: Chainlit chat settings (gear) — Skill pack; when not "Auto", overrides CHAINLIT_SKILL_PROFILE.
# CHAINLIT_SKILL_PROFILE=auto
#   auto | orchestrator | full | planner | qase-designer | automation | executor | healer
# (auto adds planner + checklists when a Jira key appears; Qase skills when “qase” is mentioned; full pipeline when keywords match)
# Or set explicit files (comma-separated paths from repo root):
# CHAINLIT_SKILL_FILES=.github/skills/orchestrator/SKILL.md,.github/rules/mcp-usage.md
# CHAINLIT_SKILL_PER_FILE_MAX=16000
# CHAINLIT_SKILLS_MAX_CHARS=50000
# Tighter caps when the message matches full-workflow phrases (saves context for MCP history)
# CHAINLIT_SKILL_PER_FILE_MAX_WORKFLOW=12000
# CHAINLIT_SKILLS_MAX_CHARS_WORKFLOW=22000
# CHAINLIT_SKILLS_VERBOSE=1
# CHAINLIT_DISABLE_SKILLS=1
#
# See the assembled OpenAI **system + user** text in Chainlit before the model answers (collapsed Step).
# CHAINLIT_PREVIEW_PROMPT_IN_CHAT=1
# CHAINLIT_PREVIEW_PROMPT_MAX_CHARS=16000
# CHAINLIT_PREVIEW_USER_MAX_CHARS=8000
# CHAINLIT_PREVIEW_INCLUDE_THREAD=0
# CHAINLIT_PREVIEW_THREAD_MESSAGE_MAX_CHARS=1200
# CHAINLIT_PREVIEW_STEP_OUTPUT_MAX=100000
# CHAINLIT_LOG_PROMPT_TO_STDERR=0
#
# Optional: force the model to call MCP on the first turn when the message looks like a Jira key (ABC-123), or for Qase mentions.
# Default is off (model uses MCP when it chooses). Set to 1 if you want tool_choice=required for those cases.
# When unset, defaults to on for fetch-style prompts ("Fetch PROJ-123", "show issue …"). Set 0 to disable.
# First MCP round forces getJiraIssue by name (not generic tools like atlassianUserInfo). Set 1 to always force when a Jira key appears.
# CHAINLIT_REQUIRE_TOOLS_FOR_ISSUE_KEY=1
# CHAINLIT_REQUIRE_TOOLS_FOR_QASE=1
# For Jira-only turns, omit Qase MCP tools so the model uses Atlassian/Jira. Full-workflow / Qase-designer phrases keep Qase.
# Set 0 to always expose both Jira and Qase in the tool list.
# CHAINLIT_EXCLUDE_QASE_FOR_JIRA_ISSUE_KEY=1
# Default test app URL injected into prompts for Qase preconditions (optional)
# CHAINLIT_TEST_BASE_URL=https://qa3.example.com
# CHAINLIT_WORKFLOW_ENV_HINTS=1
# ANTHROPIC_API_KEY=

# Optional: LLM provider (openai | anthropic). Default: openai
# LLM_PROVIDER=openai

# GitHub PAT — automation (branch, PR) and GitHub MCP (issues, files). https://github.com/settings/tokens
# For MCP: use **repo** scope; set **CHAINLIT_MCP_FULL_ENV=1** so the GitHub MCP process inherits this variable (or configure the same token in your MCP server args).
GITHUB_TOKEN=
# or GH_TOKEN=  or GH_PAT=

# ── Human-loop orchestrator (scripts/orchestrator/server.ts) ──
# ORCHESTRATOR_PORT=3847
# ORCHESTRATOR_API_TOKEN=generate-a-long-random-secret
# ORCHESTRATOR_DATA_DIR=./orchestrator-data
# ORCHESTRATOR_GITHUB_REPO=owner/ae-qa-agentic
# ORCHESTRATOR_GITHUB_TOKEN=ghp_…  # repo scope + workflow (to dispatch human-loop-qa)
# ORCHESTRATOR_PUBLIC_URL=https://your-orchestrator.example.com
# AUTO_DISPATCH_PLANNER_ON_ISSUE_CREATE=false
# GITHUB_WEBHOOK_SECRET=  # optional: GitHub webhook HMAC secret
# WEBHOOK_SHARED_SECRET=  # optional: require X-Webhook-Secret on /webhooks/*
